{
  "name": "faceless-studio",
  "version": "0.1.0",
  "description": "Faceless web-animation video studio",
  "main": "./out/main/index.js",
  "license": "MIT",
  "author": "Faceless Studio",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "icon": "node scripts/make-icon.mjs",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac dmg",
    "dist:win": "npm run build && electron-builder --win nsis"
  },
  "build": {
    "appId": "com.faceless.studio",
    "productName": "Faceless Studio",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/ffmpeg-static/**"
    ],
    "npmRebuild": false,
    "mac": {
      "target": [
        "dmg"
      ],
      "category": "public.app-category.video",
      "icon": "build/icon.png"
    },
    "dmg": {
      "title": "Faceless Studio"
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "AudioVideo",
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "ffmpeg-static": "^5.3.0",
    "lucide-react": "^1.21.0",
    "modern-screenshot": "^4.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^2.3.0",
    "gsap": "^3.15.0",
    "motion": "^12.40.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  }
}
